# Токен вашего бота из @BotFather — проверка подписи initData и Login Widget
BOT_TOKEN=123456:ABC-DEF...

# Telegram ID гарантов/арбитров через запятую (ручное подтверждение оплат)
ADMIN_IDS=
# Необязательный chat_id основной админ-группы/супергруппы, куда бот шлёт служебные уведомления
ADMIN_GROUP_ID=

# --- xRocket ---
# API-ключ Rocket Pay: @xRocket → Rocket Pay → Create App → API Key
XROCKET_API_KEY=
# База API (тестовая среда: https://dev-pay.xrocket.tg)
XROCKET_API_URL=https://pay.xrocket.tg

# --- PGon ---
# База API и ключ шлюза (поля запроса поправьте под документацию в server.js)
PGON_API_URL=
PGON_API_KEY=

# --- NicePay (nicepay.io) ---
NICEPAY_MERCHANT_ID=
NICEPAY_SECRET=

# --- RuKassa (lk.rukassa.pro) ---
RUKASSA_SHOP_ID=
RUKASSA_TOKEN=

# --- Bitpapa ---
# Токен API для автопроверки входящих переводов (bitpapa.com → API)
BITPAPA_API_TOKEN=

# Секрет вебхуков шлюзов: добавьте его в URL вебхука в кабинете шлюза,
# например https://ваш-домен/webhook/rukassa?secret=ЭТО_ЗНАЧЕНИЕ
WEBHOOK_SECRET=

# Публичный URL этого бэкенда (для callback-ссылок в счетах)
PUBLIC_URL=https://garant.example.com

# Комиссия гаранта в процентах (должна совпадать с js/config.js)
FEE_PERCENT=5

# Порт HTTP-сервера
PORT=3000

# --- Продакшен ---
# Режим production: отключает локальный админ-обход без авторизации
NODE_ENV=production
# Локальный админ-доступ с 127.0.0.1 без авторизации (только для разработки!)
# В production включайте лишь осознанно: LOCAL_ADMIN=1
LOCAL_ADMIN=0
# За reverse-proxy (nginx и т.п.) укажите количество прокси-хопов,
# чтобы req.ip показывал реального клиента: TRUST_PROXY=1
TRUST_PROXY=
# Лимит запросов к /api и /webhook c одного IP в минуту (0 — отключить)
RATE_LIMIT_PER_MIN=300
# Максимальный возраст initData Mini App в секундах (защита от replay)
INITDATA_MAX_AGE=86400
# Каталог файлов данных (deals.json и т.п.) — вынесите на постоянный том
DATA_DIR=
