# Токен вашего бота из @BotFather — нужен для проверки подписи initData Mini App
BOT_TOKEN=123456:ABC-DEF...

# API-ключ Rocket Pay: @xRocket → Rocket Pay → Create App → API Key
XROCKET_API_KEY=

# База API xRocket Pay (тестовая среда: https://dev-pay.xrocket.tg)
XROCKET_API_URL=https://pay.xrocket.tg

# Публичный URL этого бэкенда (для callback-ссылок в счетах)
PUBLIC_URL=https://garant.example.com

# Токен API Bitpapa (bitpapa.com → настройки → API) — для проверки входящих переводов
BITPAPA_API_TOKEN=

# Комиссия гаранта в процентах (должна совпадать с js/config.js)
FEE_PERCENT=5

# Порт HTTP-сервера
PORT=3000
